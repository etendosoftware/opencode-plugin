{
  "name": "opencode-claude-bridge-plugin",
  "version": "1.0.3",
  "description": "OpenCode plugin to resume Claude Code sessions inside OpenCode without losing context.",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
