  "author": "Etendo Software",
  "dependencies": {
    "@opencode-ai/plugin": "1.4.7"
  },
  "devDependencies": {
    "@types/node": "22.13.9",
    "typescript": "5.8.2",
    "vitest": "^4.1.5"
  }
}
